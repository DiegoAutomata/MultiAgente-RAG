# ============================================================
# Enterprise RAG Auditor — Variables de Entorno
# Copia este archivo a .env.local y completa los valores
# ============================================================

# --- Supabase (REQUERIDO) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service Role Key — Requerido para el pipeline de ingesta y búsqueda vectorial.
# Obtener en: Supabase Dashboard → Settings → API → service_role key
# NUNCA expongas esta clave en el frontend.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Anthropic (REQUERIDO) ---
# Usada por el chat multi-agente (Claude 3 Haiku).
# Obtener en: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# --- App (REQUERIDO) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Python Pipeline (REQUERIDO en desarrollo local) ---
# Ruta absoluta al binario de Python con las dependencias instaladas.
# Crear entorno: python -m venv .venv && source .venv/bin/activate && pip install -r requirements.txt
# NOTA: Este pipeline NO es compatible con Vercel. En producción se requiere un worker externo
# (Railway, Cloud Run, Supabase Edge Function, etc.)
PYTHON_BIN=/path/to/your/venv/bin/python

# --- LlamaParse (OPCIONAL) ---
# Mejora la calidad del parseo de PDFs. Sin esta key se usa PyPDF (open source).
# Obtener en: https://cloud.llamaindex.ai
LLAMA_CLOUD_API_KEY=llx-...

# --- Voyage AI (OPCIONAL) ---
# Embeddings de mayor calidad que all-MiniLM-L6-v2. Sin esta key se usan embeddings locales (Xenova).
# Obtener en: https://www.voyageai.com
VOYAGE_API_KEY=pa-...
